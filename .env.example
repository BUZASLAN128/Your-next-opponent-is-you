# Local development only. Do not reuse these values in a shared environment.
YNOY_POSTGRES_PORT=55432
YNOY_DB_NAME=ynoy
YNOY_DB_USER=ynoy
YNOY_DB_PASSWORD=ynoy_local_dev_only
YNOY_DATABASE_URL=postgresql://ynoy:ynoy_local_dev_only@127.0.0.1:55432/ynoy

# Must resolve outside every Git worktree before handling real identity data.
YNOY_PRIVATE_ROOT=C:/Users/YOUR_USER/AppData/Local/ynoy-private

# Optional POSIX alternative: an absolute bind path inside YNOY_PRIVATE_ROOT.
# YNOY_POSTGRES_DATA_PATH=/home/YOUR_USER/.local/share/ynoy-private/postgres

# Optional loopback-only model adapters. Use a full OpenAI-compatible
# chat-completions endpoint. The reviewed extractor experiment can be started
# from an already downloaded, hash-verified artifact with
# scripts/start-local-extractor.ps1.
# YNOY_LOCAL_REASONER_URL=http://127.0.0.1:18100/v1/chat/completions
# Set true only after verifying that the loopback endpoint cannot proxy or
# forward requests to another machine/provider.
YNOY_LOCAL_MODEL_ATTESTED=false
YNOY_LOCAL_REASONER_MODEL=ynoy-extractor-qwen3-8b-q4km
# Experimental Qwen3-8B Q4_K_M pin; not a product-default decision.
YNOY_LOCAL_REASONER_REVISION=7c41481f57cb95916b40956ab2f0b139b296d974
YNOY_LOCAL_REASONER_ARTIFACT_SHA256=d98cdcbd03e17ce47681435b5150e34c1417f50b5c0019dd560e4882c5745785
YNOY_EMBEDDING_MODEL=BAAI/bge-m3
